<?xml version = "1.0" encoding = "utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
    <class name="com.jaapec.tenant.plans.domain.Plan" table="plans">
        <composite-id name="id" class="com.jaapec.tenant.plans.domain.value_objects.PlanId" access="field">
            <key-property column="id" name="value" access="field" type="string" length="255"/>
        </composite-id>
        <component name="name" class="com.jaapec.tenant.plans.domain.value_objects.PlanName" access="field">
            <property name="value" column="name" length="255" access="field" not-null="true" unique="true"/>
        </component>
        <component name="description" class="com.jaapec.tenant.plans.domain.value_objects.PlanDescription"
                   access="field">
            <property name="value" column="description" length="255" access="field" not-null="true"/>
        </component>
        <component name="priceMonthly" class="com.jaapec.tenant.plans.domain.value_objects.PlanPriceMonthly"
                   access="field">
            <property name="value" column="price_monthly" length="255" access="field" not-null="true"/>
        </component>
        <component name="priceYearly" class="com.jaapec.tenant.plans.domain.value_objects.PlanPriceYearly"
                   access="field">
            <property name="value" column="price_yearly" length="255" access="field" not-null="true"/>
        </component>
        <component name="maxUsers" class="com.jaapec.tenant.plans.domain.value_objects.PlanMaxUsers" access="field">
            <property name="value" column="max_users" length="255" access="field" not-null="true"/>
        </component>
        <component name="maxRoles" class="com.jaapec.tenant.plans.domain.value_objects.PlanMaxRoles" access="field">
            <property name="value" column="max_roles" length="255" access="field" not-null="true"/>
        </component>
        <component name="maxAccounts" class="com.jaapec.tenant.plans.domain.value_objects.PlanMaxAccounts"
                   access="field">
            <property name="value" column="max_accounts" length="255" access="field" not-null="true"/>
        </component>
        <component name="maxInvoices" class="com.jaapec.tenant.plans.domain.value_objects.PlanMaxInvoices"
                   access="field">
            <property name="value" column="max_invoices" length="255" access="field" not-null="true"/>
        </component>
        <component name="status" class="com.jaapec.tenant.plans.domain.value_objects.PlanStatus" access="field">
            <property name="value" column="status" length="255" access="field" not-null="true"/>
        </component>
        <component name="visibility" class="com.jaapec.tenant.plans.domain.value_objects.PlanVisibility" access="field">
            <property name="value" column="visibility" length="255" access="field" not-null="true"/>
        </component>
        <component name="trialDays" class="com.jaapec.tenant.plans.domain.value_objects.PlanTrialDays" access="field">
            <property name="value" column="trial_days" length="255" access="field" not-null="true"/>
        </component>
        <component name="createdAt" class="com.jaapec.tenant.plans.domain.value_objects.PlanCreatedAt" access="field">
            <property name="value" column="created_at" length="255" access="field" not-null="true"/>
        </component>
        <component name="updatedAt" class="com.jaapec.tenant.plans.domain.value_objects.PlanUpdatedAt" access="field">
            <property name="value" column="updated_at" length="255" access="field" not-null="true"/>
        </component>
    </class>
</hibernate-mapping>
