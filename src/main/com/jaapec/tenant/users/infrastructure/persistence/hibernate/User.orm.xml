<?xml version = "1.0" encoding = "utf-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
    <class name="com.jaapec.tenant.users.domain.User" table="users">
        <composite-id name="id" class="com.jaapec.tenant.users.domain.UserId" access="field">
            <key-property column="id" name="value" access="field" type="string" length="255"/>
        </composite-id>
        <component name="name" class="com.jaapec.tenant.users.domain.UserName" access="field">
            <property name="value" column="name" length="255" access="field" not-null="true" />
        </component>
        <component name="email" class="com.jaapec.tenant.users.domain.UserEmail" access="field">
            <property name="value" column="email" length="255" access="field" not-null="true" />
        </component>
    </class>
</hibernate-mapping>
